// ==========================================
// 7. CALCULATED COLUMNS (DIMDATE)
// ==========================================

// ----------------------------------------------------------------------------
// Calculated Column Name : DimDate[MonthCode]
// Project      : DW_FamilyFinance
// Author       : Behailu Tessema
// Version      : 2.0
//
// Purpose:
//     Supports the DW_FamilyFinance Power BI semantic model and dashboard reporting.
//
// Business Question:
//     What business insight does this calculation provide?
//
// Used In:
//     Power BI report pages and supporting visuals
//
// Dependencies:
//     See DAX expression below
//
// Returns:
//     Depends on expression result
// ----------------------------------------------------------------------------

DimDate[MonthCode] = 
FORMAT(DimDate[FullDate], "MMM")

// ----------------------------------------------------------------------------
// Calculated Column Name : DimDate[YearWeek]
// Project      : DW_FamilyFinance
// Author       : Behailu Tessema
// Version      : 2.0
//
// Purpose:
//     Supports the DW_FamilyFinance Power BI semantic model and dashboard reporting.
//
// Business Question:
//     What business insight does this calculation provide?
//
// Used In:
//     Power BI report pages and supporting visuals
//
// Dependencies:
//     See DAX expression below
//
// Returns:
//     Depends on expression result
// ----------------------------------------------------------------------------

DimDate[YearWeek] = 
FORMAT(DimDate[FullDate], "YYYY") & "-W" & FORMAT(WEEKNUM(DimDate[FullDate], 2), "00")

// ----------------------------------------------------------------------------
// Calculated Column Name : DimDate[ISO_Thursday]
// Project      : DW_FamilyFinance
// Author       : Behailu Tessema
// Version      : 2.0
//
// Purpose:
//     Supports the DW_FamilyFinance Power BI semantic model and dashboard reporting.
//
// Business Question:
//     What business insight does this calculation provide?
//
// Used In:
//     Power BI report pages and supporting visuals
//
// Dependencies:
//     See DAX expression below
//
// Returns:
//     Depends on expression result
// ----------------------------------------------------------------------------

DimDate[ISO_Thursday] = 
'DimDate'[FullDate] - WEEKDAY(DimDate[FullDate], 2) + 4

// ----------------------------------------------------------------------------
// Calculated Column Name : DimDate[ISO_Year]
// Project      : DW_FamilyFinance
// Author       : Behailu Tessema
// Version      : 2.0
//
// Purpose:
//     Supports the DW_FamilyFinance Power BI semantic model and dashboard reporting.
//
// Business Question:
//     What business insight does this calculation provide?
//
// Used In:
//     Power BI report pages and supporting visuals
//
// Dependencies:
//     See DAX expression below
//
// Returns:
//     Depends on expression result
// ----------------------------------------------------------------------------

DimDate[ISO_Year] = 
YEAR ( 'DimDate'[ISO_Thursday] )

// ----------------------------------------------------------------------------
// Calculated Column Name : DimDate[ISO_Week]
// Project      : DW_FamilyFinance
// Author       : Behailu Tessema
// Version      : 2.0
//
// Purpose:
//     Supports the DW_FamilyFinance Power BI semantic model and dashboard reporting.
//
// Business Question:
//     What business insight does this calculation provide?
//
// Used In:
//     Power BI report pages and supporting visuals
//
// Dependencies:
//     See DAX expression below
//
// Returns:
//     Depends on expression result
// ----------------------------------------------------------------------------

DimDate[ISO_Week] = 
WEEKNUM ( 'DimDate'[ISO_Thursday], 2 )

// ----------------------------------------------------------------------------
// Calculated Column Name : DimDate[ISO_YearWeek]
// Project      : DW_FamilyFinance
// Author       : Behailu Tessema
// Version      : 2.0
//
// Purpose:
//     Supports the DW_FamilyFinance Power BI semantic model and dashboard reporting.
//
// Business Question:
//     What business insight does this calculation provide?
//
// Used In:
//     Power BI report pages and supporting visuals
//
// Dependencies:
//     See DAX expression below
//
// Returns:
//     Depends on expression result
// ----------------------------------------------------------------------------

DimDate[ISO_YearWeek] = 
FORMAT ( 'DimDate'[ISO_Year], "0000" ) & "-W" & FORMAT ( 'DimDate'[ISO_Week], "00" )

// ----------------------------------------------------------------------------
// Calculated Column Name : DimDate[ISO_YearWeek_Sort]
// Project      : DW_FamilyFinance
// Author       : Behailu Tessema
// Version      : 2.0
//
// Purpose:
//     Supports the DW_FamilyFinance Power BI semantic model and dashboard reporting.
//
// Business Question:
//     What business insight does this calculation provide?
//
// Used In:
//     Power BI report pages and supporting visuals
//
// Dependencies:
//     See DAX expression below
//
// Returns:
//     Depends on expression result
// ----------------------------------------------------------------------------

DimDate[ISO_YearWeek_Sort] = 
'DimDate'[ISO_Year] * 100 + 'DimDate'[ISO_Week]

// ----------------------------------------------------------------------------
// Calculated Column Name : DimDate[ISO_WeekStart]
// Project      : DW_FamilyFinance
// Author       : Behailu Tessema
// Version      : 2.0
//
// Purpose:
//     Supports the DW_FamilyFinance Power BI semantic model and dashboard reporting.
//
// Business Question:
//     What business insight does this calculation provide?
//
// Used In:
//     Power BI report pages and supporting visuals
//
// Dependencies:
//     See DAX expression below
//
// Returns:
//     Depends on expression result
// ----------------------------------------------------------------------------

DimDate[ISO_WeekStart] = 
VAR th = 'DimDate'[ISO_Thursday]
RETURN th - WEEKDAY ( th, 2 ) + 1

// ----------------------------------------------------------------------------
// Calculated Column Name : DimDate[ISO_WeekEnd]
// Project      : DW_FamilyFinance
// Author       : Behailu Tessema
// Version      : 2.0
//
// Purpose:
//     Supports the DW_FamilyFinance Power BI semantic model and dashboard reporting.
//
// Business Question:
//     What business insight does this calculation provide?
//
// Used In:
//     Power BI report pages and supporting visuals
//
// Dependencies:
//     See DAX expression below
//
// Returns:
//     Depends on expression result
// ----------------------------------------------------------------------------

DimDate[ISO_WeekEnd] = 
'DimDate'[ISO_WeekStart] + 6

// ----------------------------------------------------------------------------
// Calculated Column Name : DimDate[ISO_YearWeek_Label]
// Project      : DW_FamilyFinance
// Author       : Behailu Tessema
// Version      : 2.0
//
// Purpose:
//     Supports the DW_FamilyFinance Power BI semantic model and dashboard reporting.
//
// Business Question:
//     What business insight does this calculation provide?
//
// Used In:
//     Power BI report pages and supporting visuals
//
// Dependencies:
//     See DAX expression below
//
// Returns:
//     Depends on expression result
// ----------------------------------------------------------------------------

DimDate[ISO_YearWeek_Label] = 
DimDate[ISO_YearWeek] & " (" &
FORMAT ( DimDate[ISO_WeekStart], "MM/dd" ) & "–" &
FORMAT ( DimDate[ISO_WeekEnd],   "MM/dd" ) & ")"

// ----------------------------------------------------------------------------
// Calculated Column Name : DimDate[QuarterName]
// Project      : DW_FamilyFinance
// Author       : Behailu Tessema
// Version      : 2.0
//
// Purpose:
//     Supports the DW_FamilyFinance Power BI semantic model and dashboard reporting.
//
// Business Question:
//     What business insight does this calculation provide?
//
// Used In:
//     Power BI report pages and supporting visuals
//
// Dependencies:
//     See DAX expression below
//
// Returns:
//     Depends on expression result
// ----------------------------------------------------------------------------

DimDate[QuarterName] = 
FORMAT(DimDate[FullDate], "\QQ")


// ==========================================
// 8. CALCULATED COLUMNS (DIM & FACT TABLES)
// ==========================================

// ----------------------------------------------------------------------------
// Calculated Column Name : DimIncomeSource[Address]
// Project      : DW_FamilyFinance
// Author       : Behailu Tessema
// Version      : 2.0
//
// Purpose:
//     Supports the DW_FamilyFinance Power BI semantic model and dashboard reporting.
//
// Business Question:
//     What business insight does this calculation provide?
//
// Used In:
//     Power BI report pages and supporting visuals
//
// Dependencies:
//     See DAX expression below
//
// Returns:
//     Depends on expression result
// ----------------------------------------------------------------------------

DimIncomeSource[Address] = 
SWITCH (
    DimIncomeSource[WorkPlace],
    "Casa Coloma",       "10410 Coloma Rd, Rancho Cordova, CA 95670",
    "CITIGUARD INC",     "700 N 10th St, Sacramento, CA 95811",
    "Windsor El Camino", "2540 Carmichael Way, Carmichael, CA 95608",
    "Family Tax",        "7610 Auburn Blvd, Citrus Heights, CA 95610",
    "ClipBoard",         "5407 Nyoda Way, Carmichael, CA 95608",
    BLANK()
)

// ----------------------------------------------------------------------------
// Calculated Column Name : DimIncomeSource[First_Name]
// Project      : DW_FamilyFinance
// Author       : Behailu Tessema
// Version      : 2.0
//
// Purpose:
//     Supports the DW_FamilyFinance Power BI semantic model and dashboard reporting.
//
// Business Question:
//     What business insight does this calculation provide?
//
// Used In:
//     Power BI report pages and supporting visuals
//
// Dependencies:
//     See DAX expression below
//
// Returns:
//     Depends on expression result
// ----------------------------------------------------------------------------

DimIncomeSource[First_Name] = 
SWITCH (
    DimIncomeSource[EmployeeFullName],
    "Behailu Tessema", "Behailu",
    "Mignote Tumoro",  "Mignote",
    DimIncomeSource[EmployeeFullName]
)

// ----------------------------------------------------------------------------
// Calculated Column Name : FactFamilyIncome[Work Period]
// Project      : DW_FamilyFinance
// Author       : Behailu Tessema
// Version      : 2.0
//
// Purpose:
//     Supports the DW_FamilyFinance Power BI semantic model and dashboard reporting.
//
// Business Question:
//     What business insight does this calculation provide?
//
// Used In:
//     Power BI report pages and supporting visuals
//
// Dependencies:
//     See DAX expression below
//
// Returns:
//     Depends on expression result
// ----------------------------------------------------------------------------

FactFamilyIncome[Work Period] = 
VAR d   = RELATED ( DimDate[FullDate] )
VAR y   = YEAR ( d )
VAR m   = MONTH ( d )
VAR dom = DAY ( d )
VAR StartDate = IF ( dom <= 15, DATE ( y, m, 1 ),  DATE ( y, m, 16 ) )
VAR EndDate   = IF ( dom <= 15, DATE ( y, m, 15 ), EOMONTH ( d, 0 ) )
RETURN
    FORMAT ( StartDate, "MM/dd/yyyy" ) & " - " & FORMAT ( EndDate, "MM/dd/yyyy" )

// ----------------------------------------------------------------------------
// Calculated Column Name : DimLocation[Color Code]
// Project      : DW_FamilyFinance
// Author       : Behailu Tessema
// Version      : 2.0
//
// Purpose:
//     Supports the DW_FamilyFinance Power BI semantic model and dashboard reporting.
//
// Business Question:
//     What business insight does this calculation provide?
//
// Used In:
//     Power BI report pages and supporting visuals
//
// Dependencies:
//     See DAX expression below
//
// Returns:
//     Depends on expression result
// ----------------------------------------------------------------------------

DimLocation[Color Code] = 
SWITCH (
    TRUE(),
    DimLocation[Work_Place] = "Casa Coloma", "Red",
    DimLocation[Work_Place] = "CITIGUARD INC", "Green",
    DimLocation[Work_Place] = "Windsor El Camino", "Purple",
    DimLocation[Work_Place] = "Family Tax", "Blue",
    "Yellow" // Fallback default value instead of broken nested IF
)


// ==========================================
// 9. CALCULATED TABLES
// ==========================================

// ----------------------------------------------------------------------------
// Calculated Table Name : DimLocation
// Project      : DW_FamilyFinance
// Author       : Behailu Tessema
// Version      : 2.0
//
// Purpose:
//     Supports the DW_FamilyFinance Power BI semantic model and dashboard reporting.
//
// Business Question:
//     What business insight does this calculation provide?
//
// Used In:
//     Power BI report pages and supporting visuals
//
// Dependencies:
//     See DAX expression below
//
// Returns:
//     Depends on expression result
// ----------------------------------------------------------------------------

DimLocation = 
DATATABLE (
    "Work_Place", STRING,
    "Street",     STRING,
    "City",       STRING,
    "State",      STRING,
    "ZIP",        STRING,
    "Address",    STRING,
    {
        { "Casa Coloma",       "10410 Coloma Rd",     "Rancho Cordova", "CA", "95670", "10410 Coloma Rd, Rancho Cordova, CA 95670" },
        { "CITIGUARD INC",     "700 N 10th St",       "Sacramento",     "CA", "95811", "700 N 10th St, Sacramento, CA 95811" },
        { "Windsor El Camino", "2540 Carmichael Way", "Carmichael",     "CA", "95608", "2540 Carmichael Way, Carmichael, CA 95608" },
        { "Family Tax",        "7610 Auburn Blvd",    "Citrus Heights", "CA", "95610", "7610 Auburn Blvd, Citrus Heights, CA 95610" },
        { "CLIPBOARD",         "5407 Nyoda Way",      "Carmichael",     "CA", "95608", "5407 Nyoda Way, Carmichael, CA 95610" }
    }
)

// ----------------------------------------------------------------------------
// Calculated Table Name : Salary Pie Category
// Project      : DW_FamilyFinance
// Author       : Behailu Tessema
