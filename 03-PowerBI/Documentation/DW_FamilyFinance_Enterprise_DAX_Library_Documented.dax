// ============================================================================
// DW_FamilyFinance
// Enterprise DAX Measure Library
//
// Author  : Behailu Tessema
// Version : 2.0
// Purpose : Documents all Power BI DAX measures, calculated columns, and
//           calculated tables used in the DW_FamilyFinance semantic model.
//
// Documentation Standard:
//     Each measure includes a business purpose, business question, usage area,
//     dependencies, and expected return type. This makes the DAX library easier
//     to maintain, review, and present as a portfolio artifact.
// ============================================================================

// ==========================================
// 1. CORE FINANCIAL MEASURES
// ==========================================

// ----------------------------------------------------------------------------
// Measure Name : Gross Payment
// Project      : DW_FamilyFinance
// Author       : Behailu Tessema
// Version      : 2.0
//
// Purpose:
//     Calculates total gross earnings before payroll taxes and deductions.
//
// Business Question:
//     How much income was earned before taxes?
//
// Used In:
//     Executive Summary; Income Analysis; Gross vs Net comparisons
//
// Dependencies:
//     FactFamilyIncome[GrossPayment]
//
// Returns:
//     Currency
// ----------------------------------------------------------------------------

[Gross Payment] = 
SUM ( FactFamilyIncome[GrossPayment] )

// ----------------------------------------------------------------------------
// Measure Name : Net Salary
// Project      : DW_FamilyFinance
// Author       : Behailu Tessema
// Version      : 2.0
//
// Purpose:
//     Calculates total take-home salary after payroll taxes and deductions.
//
// Business Question:
//     How much income was actually received?
//
// Used In:
//     Executive Summary; Income Analysis; Savings Analysis
//
// Dependencies:
//     FactFamilyIncome[EmployerNetPay]
//
// Returns:
//     Currency
// ----------------------------------------------------------------------------

[Net Salary] = 
SUM ( FactFamilyIncome[EmployerNetPay] )

// ----------------------------------------------------------------------------
// Measure Name : Net Income
// Project      : DW_FamilyFinance
// Author       : Behailu Tessema
// Version      : 2.0
//
// Purpose:
//     Calculates net income for dashboard visuals. In this model it is equivalent to Net Salary.
//
// Business Question:
//     How much usable income is available after payroll deductions?
//
// Used In:
//     Executive Summary; Income Analysis; Savings Analysis
//
// Dependencies:
//     FactFamilyIncome[EmployerNetPay]
//
// Returns:
//     Currency
// ----------------------------------------------------------------------------

[Net Income] = 
-- Duplicate of Net Salary used across separate visual cards
SUM ( FactFamilyIncome[EmployerNetPay] )

// ----------------------------------------------------------------------------
// Measure Name : Total Expense
// Project      : DW_FamilyFinance
// Author       : Behailu Tessema
// Version      : 2.0
//
// Purpose:
//     Calculates total household spending across all expense transactions and returns zero when no expenses exist.
//
// Business Question:
//     How much money was spent during the selected period?
//
// Used In:
//     Executive Summary; Expense Analysis; Savings Analysis
//
// Dependencies:
//     FactFamilyExpense[ExpenseAmount]
//
// Returns:
//     Currency
// ----------------------------------------------------------------------------

[Total Expense] = 
VAR Result = SUM ( 'FactFamilyExpense'[ExpenseAmount] )
RETURN
    IF ( ISBLANK ( Result ), 0, Result )

// ----------------------------------------------------------------------------
// Measure Name : Net Savings
// Project      : DW_FamilyFinance
// Author       : Behailu Tessema
// Version      : 2.0
//
// Purpose:
//     Calculates remaining income after subtracting total expenses from net salary.
//
// Business Question:
//     Did the household save money during the selected period?
//
// Used In:
//     Executive Summary; Savings Analysis; KPI cards
//
// Dependencies:
//     [Net Salary]; [Total Expense]
//
// Returns:
//     Currency
// ----------------------------------------------------------------------------

[Net Savings] = 
[Net Salary] - [Total Expense]

// ----------------------------------------------------------------------------
// Measure Name : Count of Pay Days
// Project      : DW_FamilyFinance
// Author       : Behailu Tessema
// Version      : 2.0
//
// Purpose:
//     Counts distinct pay dates in the payroll fact table.
//
// Business Question:
//     How many pay days occurred in the selected period?
//
// Used In:
//     Income Analysis; Operational KPI cards
//
// Dependencies:
//     FactFamilyIncome[PayDateKey]
//
// Returns:
//     Whole number
// ----------------------------------------------------------------------------

[Count of Pay Days] = 
DISTINCTCOUNT ( FactFamilyIncome[PayDateKey] )

// ----------------------------------------------------------------------------
// Measure Name : Daily Expense
// Project      : DW_FamilyFinance
// Author       : Behailu Tessema
// Version      : 2.0
//
// Purpose:
//     Calculates expenses classified as daily expenses.
//
// Business Question:
//     How much spending belongs to daily expense activity?
//
// Used In:
//     Expense Analysis; Category drilldowns
//
// Dependencies:
//     [Total Expense]; DimDescription[ExpenseType]
//
// Returns:
//     Currency
// ----------------------------------------------------------------------------

[Daily Expense] = 
CALCULATE ( [Total Expense], DimDescription[ExpenseType] = "DAILY EXPENSES" )

// ----------------------------------------------------------------------------
// Measure Name : Fixed Expense
// Project      : DW_FamilyFinance
// Author       : Behailu Tessema
// Version      : 2.0
//
// Purpose:
//     Calculates yearly fixed expense while preserving the current year context.
//
// Business Question:
//     How much fixed spending occurred by year?
//
// Used In:
//     Expense Analysis; yearly comparisons
//
// Dependencies:
//     [Total Expense]; DimDate[Year]
//
// Returns:
//     Currency
// ----------------------------------------------------------------------------

[Fixed Expense] = 
CALCULATE ( [Total Expense], ALLEXCEPT( ( 'FactFamilyExpense' ), DimDate[Year]))

// ----------------------------------------------------------------------------
// Measure Name : Fixed Salary
// Project      : DW_FamilyFinance
// Author       : Behailu Tessema
// Version      : 2.0
//
// Purpose:
//     Calculates yearly salary while preserving the current year context.
//
// Business Question:
//     How much salary was earned by year?
//
// Used In:
//     Income Analysis; yearly comparisons
//
// Dependencies:
//     [Net Salary]; DimDate[Year]
//
// Returns:
//     Currency
// ----------------------------------------------------------------------------

[Fixed Salary] = 
CALCULATE ( [Net Salary], ALLEXCEPT( ( 'FactFamilyExpense' ), DimDate[Year]))


