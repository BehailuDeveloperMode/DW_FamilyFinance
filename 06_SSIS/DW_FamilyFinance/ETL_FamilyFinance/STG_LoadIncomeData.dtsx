      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{B32620D0-DC98-42C3-B3B4-4103FDA4927C}"
          SQLTask:SqlStatementSource="SELECT ISNULL(CONVERT (DATE, MAX(Pay_Day)), CONVERT (DATE, '19000101')) AS Max_Date&#xA;FROM   [STG_FamilyLiving].[dbo].[Family_Income];"
          SQLTask:ResultType="ResultSetType_SingleRow" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask">
