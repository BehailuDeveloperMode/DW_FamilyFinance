      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{B32620D0-DC98-42C3-B3B4-4103FDA4927C}"
          SQLTask:SqlStatementSource="SELECT&#xA;    ISNULL(&#xA;        CAST(MAX(Pay_Day) AS DATETIME),&#xA;        CAST('19000101' AS DATETIME)&#xA;    ) AS NewMaxIncomeDate&#xA;FROM STG_FamilyLiving.dbo.Family_Income;"
          SQLTask:ResultType="ResultSetType_SingleRow" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask">
          <SQLTask:ResultBinding
            SQLTask:ResultName="NewMaxIncomeDate"
            SQLTask:DtsVariableName="User::NewMaxIncomeDate" />
        </SQLTask:SqlTaskData>
      </DTS:ObjectData>
    </DTS:Executable>
